<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>Elite Sprint Tracker</title>
    <style>
        :root {
            --bg-color: #0b0f19;
            --panel-bg: rgba(26, 32, 53, 0.7);
            --primary: #00e5ff;
            --primary-glow: rgba(0, 229, 255, 0.4);
            --success: #00ff88;
            --danger: #ff3366;
            --warning: #ffcc00;
            --text-main: #ffffff;
            --text-muted: #8a94a6;
            --font-main: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
        }

        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
            font-family: var(--font-main);
            -webkit-tap-highlight-color: transparent;
        }

        body {
            background-color: var(--bg-color);
            color: var(--text-main);
            display: flex;
            flex-direction: column;
            align-items: center;
            min-height: 100vh;
            padding: 20px 15px;
            background-image: radial-gradient(circle at 50% 0%, #1a2035 0%, #0b0f19 60%);
        }

        /* --- Header & Distance Selection --- */
        .header-title {
            font-size: 20px;
            font-weight: 800;
            text-transform: uppercase;
            letter-spacing: 2px;
            color: var(--primary);
            margin-bottom: 25px;
            text-shadow: 0 0 10px var(--primary-glow);
        }

        .distance-selector {
            display: flex;
            gap: 8px;
            width: 100%;
            max-width: 400px;
            margin-bottom: 20px;
            background: rgba(0,0,0,0.3);
            padding: 5px;
            border-radius: 12px;
        }

        .dist-btn {
            flex: 1;
            background: transparent;
            border: none;
            color: var(--text-muted);
            padding: 10px 0;
            border-radius: 8px;
            font-size: 15px;
            font-weight: 700;
            cursor: pointer;
            transition: all 0.3s ease;
        }

        .dist-btn.active {
            background: var(--primary);
            color: #000;
            box-shadow: 0 0 15px var(--primary-glow);
        }

        /* --- GPS Connection Card --- */
        .gps-card {
            width: 100%;
            max-width: 400px;
            background: var(--panel-bg);
            border-radius: 16px;
            padding: 15px;
            margin-bottom: 20px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            border: 1px solid rgba(255,255,255,0.05);
            backdrop-filter: blur(10px);
        }

        .gps-info {
            display: flex;
            flex-direction: column;
        }

        .gps-status-title { font-size: 12px; color: var(--text-muted); text-transform: uppercase; letter-spacing: 1px;}
        .gps-status-text { font-size: 14px; font-weight: 600; color: var(--warning); margin-top: 4px;}
        .gps-status-text.connected { color: var(--success); }
        .gps-status-text.error { color: var(--danger); }

        .btn-connect {
            background: transparent;
            border: 2px solid var(--primary);
            color: var(--primary);
            padding: 8px 16px;
            border-radius: 8px;
            font-weight: bold;
            font-size: 12px;
            text-transform: uppercase;
            cursor: pointer;
            transition: 0.2s;
        }
        .btn-connect:active { transform: scale(0.95); }

        /* --- Main Dashboard --- */
        .dashboard {
            width: 100%;
            max-width: 400px;
            background: var(--panel-bg);
            border-radius: 24px;
            padding: 30px 20px;
            text-align: center;
            border: 1px solid rgba(255,255,255,0.05);
            backdrop-filter: blur(10px);
            margin-bottom: 20px;
            position: relative;
        }

        .timer-container { margin-bottom: 25px; }
        
        .timer {
            font-size: 64px;
            font-weight: 800;
            font-variant-numeric: tabular-nums;
            line-height: 1;
            text-shadow: 0 0 20px rgba(255,255,255,0.2);
        }
        
        .timer-ms { font-size: 28px; color: var(--text-muted); }

        /* Progress Bar */
        .progress-wrapper {
            width: 100%;
            height: 8px;
            background: rgba(0,0,0,0.5);
            border-radius: 4px;
            margin-bottom: 10px;
            overflow: hidden;
        }
        .progress-fill {
            height: 100%;
            width: 0%;
            background: linear-gradient(90deg, var(--primary), var(--success));
            border-radius: 4px;
            transition: width 0.3s ease;
        }
        .distance-text {
            font-size: 16px;
            font-weight: 700;
            color: var(--success);
            letter-spacing: 1px;
        }

        /* Stats Grid */
        .stats-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 15px;
            margin-top: 25px;
            border-top: 1px solid rgba(255,255,255,0.1);
            padding-top: 20px;
        }

        .stat-box {
            display: flex;
            flex-direction: column;
            align-items: center;
        }

        .stat-label { font-size: 11px; color: var(--text-muted); text-transform: uppercase; letter-spacing: 1px; margin-bottom: 5px; }
        .stat-value { font-size: 22px; font-weight: 700; font-variant-numeric: tabular-nums; }
        .stat-unit { font-size: 12px; color: var(--text-muted); }

        /* --- Controls --- */
        .controls {
            display: flex;
            gap: 15px;
            width: 100%;
            max-width: 400px;
        }

        .btn-action {
            flex: 1;
            padding: 18px;
            border-radius: 16px;
            border: none;
            font-size: 18px;
            font-weight: 800;
            text-transform: uppercase;
            cursor: pointer;
            transition: all 0.2s;
            color: #000;
        }

        .btn-action:disabled {
            background: #2a3045 !important;
            color: var(--text-muted) !important;
            box-shadow: none !important;
            cursor: not-allowed;
        }

        .btn-start { background: var(--success); box-shadow: 0 5px 20px rgba(0, 255, 136, 0.3); }
        .btn-stop { background: var(--danger); box-shadow: 0 5px 20px rgba(255, 51, 102, 0.3); display: none; color: white;}
        .btn-reset { background: rgba(255,255,255,0.1); color: white; border: 1px solid rgba(255,255,255,0.2); }

    </style>
</head>
<body>

    <div class="header-title">Elite Tracker</div>

    <div class="distance-selector" id="distSelector">
        <button class="dist-btn active" data-dist="100">100m</button>
        <button class="dist-btn" data-dist="200">200m</button>
        <button class="dist-btn" data-dist="300">300m</button>
        <button class="dist-btn" data-dist="400">400m</button>
    </div>

    <!-- New GPS Connection Card -->
    <div class="gps-card">
        <div class="gps-info">
            <span class="gps-status-title">Satellite Link</span>
            <span class="gps-status-text" id="gpsStatusText">Disconnected</span>
        </div>
        <button class="btn-connect" id="connectGpsBtn">Connect GPS</button>
    </div>

    <div class="dashboard">
        <div class="timer-container">
            <div class="timer" id="timerDisplay">00:00<span class="timer-ms">.00</span></div>
        </div>
        
        <div class="progress-wrapper">
            <div class="progress-fill" id="progressBar"></div>
        </div>
        <div class="distance-text" id="distanceDisplay">0.0m / 100m</div>

        <div class="stats-grid">
            <div class="stat-box">
                <span class="stat-label">Current Speed</span>
                <span class="stat-value" id="currentSpeed">0.0</span>
                <span class="stat-unit">km/h</span>
            </div>
            <div class="stat-box">
                <span class="stat-label">Top Speed</span>
                <span class="stat-value" id="topSpeed">0.0</span>
                <span class="stat-unit">km/h</span>
            </div>
        </div>
    </div>

    <div class="controls">
        <button class="btn-action btn-reset" id="resetBtn">Reset</button>
        <button class="btn-action btn-start" id="startBtn" disabled>Start</button>
        <button class="btn-action btn-stop" id="stopBtn">Stop</button>
    </div>

    <script>
        // --- State Variables ---
        let targetDistance = 100;
        let currentDistance = 0;
        let isRunning = false;
        let gpsLocked = false;
        
        let startTime = 0;
        let timerInterval = null;
        let watchId = null;
        let lastPosition = null;
        
        let maxSpeed = 0;

        // --- DOM Elements ---
        const distButtons = document.querySelectorAll('.dist-btn');
        const timerDisplay = document.getElementById('timerDisplay');
        const distanceDisplay = document.getElementById('distanceDisplay');
        const progressBar = document.getElementById('progressBar');
        const currentSpeedEl = document.getElementById('currentSpeed');
        const topSpeedEl = document.getElementById('topSpeed');
        
        const gpsStatusText = document.getElementById('gpsStatusText');
        const connectGpsBtn = document.getElementById('connectGpsBtn');
        
        const startBtn = document.getElementById('startBtn');
        const stopBtn = document.getElementById('stopBtn');
        const resetBtn = document.getElementById('resetBtn');
        const distSelector = document.getElementById('distSelector');

        // --- Event Listeners ---
        distButtons.forEach(btn => {
            btn.addEventListener('click', () => {
                if (isRunning) return; 
                distButtons.forEach(b => b.classList.remove('active'));
                btn.classList.add('active');
                targetDistance = parseInt(btn.getAttribute('data-dist'));
                updateUI();
            });
        });

        connectGpsBtn.addEventListener('click', initializeGPS);
        startBtn.addEventListener('click', startSprint);
        stopBtn.addEventListener('click', stopSprint);
        resetBtn.addEventListener('click', resetApp);

        // --- Math Helpers ---
        function calculateDistance(lat1, lon1, lat2, lon2) {
            const R = 6371e3; 
            const toRad = (value) => value * Math.PI / 180;
            const phi1 = toRad(lat1);
            const phi2 = toRad(lat2);
            const deltaPhi = toRad(lat2 - lat1);
            const deltaLambda = toRad(lon2 - lon1);

            const a = Math.sin(deltaPhi / 2) * Math.sin(deltaPhi / 2) +
                      Math.cos(phi1) * Math.cos(phi2) *
                      Math.sin(deltaLambda / 2) * Math.sin(deltaLambda / 2);
            const c = 2 * Math.atan2(Math.sqrt(a), Math.sqrt(1 - a));
            return R * c; 
        }

        // --- Pre-Race GPS Initialization ---
        function initializeGPS() {
            if (!navigator.geolocation) {
                alert("Geolocation is not supported by your browser.");
                return;
            }

            gpsStatusText.innerText = "Acquiring Signal...";
            gpsStatusText.className = "gps-status-text";
            connectGpsBtn.disabled = true;
            connectGpsBtn.innerText = "Waiting...";

            // Request permission and get initial lock
            navigator.geolocation.getCurrentPosition(
                (position) => {
                    if(position.coords.accuracy <= 20) {
                        gpsLocked = true;
                        gpsStatusText.innerText = `Locked (Acc: ${Math.round(position.coords.accuracy)}m)`;
                        gpsStatusText.className = "gps-status-text connected";
                        connectGpsBtn.style.display = "none";
                        startBtn.disabled = false; // Unlock start button
                        startBtn.innerText = "START SPRINT";
                    } else {
                        gpsStatusText.innerText = "Weak Signal. Move outside.";
                        connectGpsBtn.disabled = false;
                        connectGpsBtn.innerText = "Retry";
                    }
                },
                (error) => {
                    gpsStatusText.innerText = "Permission Denied/Error";
                    gpsStatusText.className = "gps-status-text error";
                    connectGpsBtn.disabled = false;
                    connectGpsBtn.innerText = "Retry";
                    alert(error.message + "\nPlease ensure Location permissions are granted.");
                },
                { enableHighAccuracy: true, timeout: 10000, maximumAge: 0 }
            );
        }

        // --- Core Tracking Logic ---
        function handlePositionUpdate(position) {
            const { latitude, longitude, accuracy, speed } = position.coords;

            // Reject highly inaccurate points
            if (accuracy > 20) return;

            if (lastPosition) {
                const distMoved = calculateDistance(
                    lastPosition.latitude, lastPosition.longitude,
                    latitude, longitude
                );

                if (distMoved > 0.5) {
                    currentDistance += distMoved;
                    
                    // Calculate speed
                    let currentSpeedKmh = 0;
                    if (speed !== null) {
                        // Native GPS speed (m/s to km/h)
                        currentSpeedKmh = speed * 3.6;
                    } else {
                        // Manual fallback calculation
                        const timeDiff = (position.timestamp - lastPosition.timestamp) / 1000; // in seconds
                        if(timeDiff > 0) {
                            currentSpeedKmh = (distMoved / timeDiff) * 3.6;
                        }
                    }

                    // Update Top Speed
                    if (currentSpeedKmh > maxSpeed) {
                        maxSpeed = currentSpeedKmh;
                    }

                    // Update DOM
                    currentSpeedEl.innerText = currentSpeedKmh.toFixed(1);
                    topSpeedEl.innerText = maxSpeed.toFixed(1);
                    updateUI();

                    // Check win condition
                    if (currentDistance >= targetDistance) {
                        finishSprint();
                    }
                }
            }

            lastPosition = { latitude, longitude, timestamp: position.timestamp };
        }

        // --- UI Updates ---
        function updateUI() {
            // Distance
            distanceDisplay.innerText = `${currentDistance.toFixed(1)}m / ${targetDistance}m`;
            
            // Progress Bar
            let progressPercent = (currentDistance / targetDistance) * 100;
            if (progressPercent > 100) progressPercent = 100;
            progressBar.style.width = `${progressPercent}%`;
        }

        function updateTimer() {
            const elapsedTime = Date.now() - startTime;
            const minutes = Math.floor(elapsedTime / 60000);
            const seconds = Math.floor((elapsedTime % 60000) / 1000);
            const milliseconds = Math.floor((elapsedTime % 1000) / 10);

            const m = minutes.toString().padStart(2, '0');
            const s = seconds.toString().padStart(2, '0');
            const ms = milliseconds.toString().padStart(2, '0');

            timerDisplay.innerHTML = `${m}:${s}<span class="timer-ms">.${ms}</span>`;
        }

        // --- App Flow Controls ---
        function startSprint() {
            if (!gpsLocked) return;

            isRunning = true;
            currentDistance = 0;
            maxSpeed = 0;
            lastPosition = null;
            
            distSelector.style.opacity = '0.4';
            distSelector.style.pointerEvents = 'none';
            
            startBtn.style.display = 'none';
            stopBtn.style.display = 'block';
            resetBtn.disabled = true;

            startTime = Date.now();
            timerInterval = setInterval(updateTimer, 10);

            watchId = navigator.geolocation.watchPosition(
                handlePositionUpdate, 
                (err) => console.warn(err), 
                { enableHighAccuracy: true, maximumAge: 0, timeout: 5000 }
            );
        }

        function stopSprint() {
            isRunning = false;
            clearInterval(timerInterval);
            if (watchId !== null) {
                navigator.geolocation.clearWatch(watchId);
                watchId = null;
            }

            startBtn.style.display = 'block';
            stopBtn.style.display = 'none';
            resetBtn.disabled = false;
            distSelector.style.opacity = '1';
            distSelector.style.pointerEvents = 'auto';
            currentSpeedEl.innerText = "0.0";
        }

        function finishSprint() {
            stopSprint();
            currentDistance = targetDistance; 
            updateUI();
            
            distanceDisplay.innerText = "TARGET REACHED!";
            distanceDisplay.style.color = "var(--primary)";
            
            if (navigator.vibrate) navigator.vibrate([300, 100, 300, 100, 500]);
        }

        function resetApp() {
            if (isRunning) return;
            currentDistance = 0;
            maxSpeed = 0;
            timerDisplay.innerHTML = `00:00<span class="timer-ms">.00</span>`;
            currentSpeedEl.innerText = "0.0";
            topSpeedEl.innerText = "0.0";
            distanceDisplay.style.color = "var(--success)";
            updateUI();
        }
    </script>
</body>
</html>
